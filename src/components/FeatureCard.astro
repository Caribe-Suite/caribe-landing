---
import { Check } from '@lucide/astro';

interface Props {
    title: string;
    description: string;
    icon: any; // Using any for the Lucide component
    items?: string[];
}

const { title, description, icon: Icon, items } = Astro.props;
---

<div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
    <div class="text-slate-800 mb-4">
        <Icon size={40} strokeWidth={1.5} />
    </div>
    <h3 class="text-xl font-bold text-slate-800 mb-3">{title}</h3>
    <p class="text-slate-600 mb-4 leading-relaxed">
        {description}
    </p>
    {items && (
        <ul class="space-y-2">
            {items.map(item => (
                <li class="flex items-start text-sm text-slate-500">
                    <Check size={16} class="mr-2 mt-0.5 text-slate-400 shrink-0" />
                    <span>{item}</span>
                </li>
            ))}
        </ul>
    )}
</div>
