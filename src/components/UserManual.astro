---
import { ChevronLeft, ChevronRight } from "@lucide/astro";

const videos = [
  {
    title: "Configuración inicial del sistema",
    description:
      "Un recorrido rápido por la configuración inicial de Caribe Suite: desde la bienvenida y creación del administrador hasta la empresa, moneda, cuentas contables, métodos de pago, clientes, proveedores, inventario y capital inicial. Todo lo necesario para dejar tu sistema listo para trabajar.",
    videoId: "oJ8yxCpUl_Q",
  },
  {
    title: "Conociendo el sistema",
    description:
      "Acompáñanos en un recorrido por Caribe Suite, donde mostramos cómo quedó configurado el sistema tras la instalación inicial. Verás el perfil de la empresa, centros de costo, roles y usuarios, además de la moneda y el plan de cuentas con sus saldos iniciales. También exploramos inventario, punto de venta y reportes contables, para que te familiarices con cada módulo y sepas dónde encontrar la información clave de tu negocio.",
    videoId: "rkYO4ZISeP8",
  },
];
---

<section id="manual" class="py-24 px-4 bg-white border-b border-slate-100">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center max-sm:text-left mb-16">
      <h2
        class="text-3xl md:text-4xl font-bold text-slate-900 mb-4 uppercase tracking-wider"
      >
        Manual de Usuario
      </h2>
      <p
        class="text-slate-500 text-lg max-w-2xl mx-auto max-sm:mx-0 leading-relaxed"
      >
        Aquí aparecerán los <strong>video‑tutoriales</strong> del sistema, organizados
        para guiarte paso a paso en cada proceso.
      </p>
    </div>

    <!-- Body: sidebar + gallery -->
    <div class="flex flex-col lg:flex-row gap-8 items-start">
      <!-- Table of Contents -->
      <aside
        class="w-full lg:w-64 shrink-0 bg-slate-50 border border-slate-200 rounded-2xl p-4 lg:sticky lg:top-8 overflow-y-auto max-h-[calc(100vh-4rem)]"
      >
        <p
          class="text-[10px] font-bold tracking-[0.1em] uppercase text-slate-400 mb-4 px-2"
        >
          Contenido
        </p>
        <nav>
          <ol
            class="flex lg:flex-col gap-2 overflow-x-auto lg:overflow-x-visible pb-2 lg:pb-0 scrollbar-none"
          >
            {
              videos.map((video, i) => (
                <li class="shrink-0 lg:shrink">
                  <a
                    href={`#video-${i}`}
                    class="toc-link flex items-baseline gap-3 px-3 py-2 rounded-xl text-slate-500 hover:bg-slate-200/50 hover:text-slate-900 transition-all whitespace-nowrap lg:whitespace-normal group"
                    data-index={i}
                  >
                    <span class="text-[10px] font-bold opacity-40 group-[.active]:opacity-100 font-mono">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <span class="text-sm font-medium leading-snug">
                      {video.title}
                    </span>
                  </a>
                </li>
              ))
            }
          </ol>
        </nav>
      </aside>

      <!-- Horizontal Gallery -->
      <div class="w-full lg:flex-1 min-w-0 relative group/gallery">
        <div
          id="gallery-track"
          class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-6 scrollbar-thin scrollbar-thumb-slate-200 scrollbar-track-transparent"
        >
          {
            videos.map((video, i) => (
              <article
                class="video-card flex-none w-full md:w-[450px] snap-start bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden"
                id={`video-${i}`}
                data-index={i}
              >
                <div class="aspect-video bg-slate-900">
                  <iframe
                    class="w-full h-full border-0"
                    src={`https://www.youtube.com/embed/${video.videoId}`}
                    title={video.title}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    referrerpolicy="strict-origin-when-cross-origin"
                    allowfullscreen
                  />
                </div>
                <div class="p-6">
                  <span class="inline-block text-[10px] font-bold tracking-widest text-slate-400 uppercase mb-2 font-mono">
                    Tutorial {String(i + 1).padStart(2, "0")}
                  </span>
                  <h3 class="text-lg font-bold text-slate-900 mb-2 leading-tight">
                    {video.title}
                  </h3>
                  <p class="text-sm text-slate-600 leading-relaxed">
                    {video.description}
                  </p>
                </div>
              </article>
            ))
          }
        </div>

        <!-- Navigation arrows -->
        <button
          id="btn-prev"
          class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 w-10 h-10 rounded-full bg-white border border-slate-200 shadow-lg hidden md:flex items-center justify-center text-slate-900 opacity-0 group-hover/gallery:opacity-100 lg:group-hover/gallery:-translate-x-5 transition-all disabled:opacity-0 z-10"
          aria-label="Anterior"
        >
          <ChevronLeft size={20} />
        </button>
        <button
          id="btn-next"
          class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 w-10 h-10 rounded-full bg-white border border-slate-200 shadow-lg hidden md:flex items-center justify-center text-slate-900 opacity-0 group-hover/gallery:opacity-100 lg:group-hover/gallery:translate-x-5 transition-all disabled:opacity-0 z-10"
          aria-label="Siguiente"
        >
          <ChevronRight size={20} />
        </button>

        <!-- Dots & Counter -->
        <div class="flex items-center justify-between mt-6">
          <div id="gallery-dots" class="flex items-center -mx-1">
            {
              videos.map((_, i) => (
                <button
                  class="dot-container group/dot w-8 h-8 flex items-center justify-center transition-all"
                  data-dot={i}
                  aria-label={`Ir al video ${i + 1}`}
                  type="button"
                >
                  <span class="dot w-1.5 h-1.5 rounded-full bg-slate-200 transition-all group-hover/dot:bg-slate-400 group-[.active]/dot:bg-slate-900 group-[.active]/dot:w-4" />
                </button>
              ))
            }
          </div>
          <div
            class="text-xs font-bold text-slate-400 font-mono tracking-tighter"
            id="gallery-counter"
          >
            <span id="counter-current" class="text-slate-900">1</span>
            <span class="mx-0.5 opacity-30">/</span>
            <span>{videos.length}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-thin::-webkit-scrollbar {
    height: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }

  .toc-link.active {
    @apply bg-slate-900 text-white shadow-md;
  }

</style>

<script>
  const track = document.getElementById("gallery-track") as HTMLElement;
  const btnPrev = document.getElementById("btn-prev") as HTMLButtonElement;
  const btnNext = document.getElementById("btn-next") as HTMLButtonElement;
  const dotContainers = document.querySelectorAll<HTMLButtonElement>(".dot-container");
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
  const counterCurrent = document.getElementById("counter-current");

  let currentIndex = 0;
  let isScrolling = false;

  function getCardWidth(): number {
    const card = track.querySelector<HTMLElement>(".video-card");
    if (!card) return 300;
    const style = getComputedStyle(track);
    const gap = parseFloat(style.gap) || 24;
    return card.offsetWidth + gap;
  }

  function scrollToIndex(index: number) {
    currentIndex = Math.max(0, Math.min(index, dotContainers.length - 1));
    isScrolling = true;
    track.scrollTo({ left: currentIndex * getCardWidth(), behavior: "smooth" });
    updateActive();
    setTimeout(() => { isScrolling = false; }, 800);
  }

  function updateActive() {
    dotContainers.forEach((d, i) => {
      const isActive = i === currentIndex;
      d.classList.toggle("active", isActive);
      if (isActive) {
        d.setAttribute("aria-current", "true");
      } else {
        d.removeAttribute("aria-current");
      }
    });
    tocLinks.forEach((l, i) => {
      const isActive = i === currentIndex;
      l.classList.toggle("active", isActive);
      if (isActive) {
        l.setAttribute("aria-current", "true");
      } else {
        l.removeAttribute("aria-current");
      }
    });
    if (counterCurrent) counterCurrent.textContent = String(currentIndex + 1);

    btnPrev.disabled = currentIndex === 0;
    btnNext.disabled = currentIndex === dotContainers.length - 1;
  }

  btnPrev?.addEventListener("click", () => scrollToIndex(currentIndex - 1));
  btnNext?.addEventListener("click", () => scrollToIndex(currentIndex + 1));

  dotContainers.forEach((dot, i) =>
    dot.addEventListener("click", () => scrollToIndex(i)),
  );

  tocLinks.forEach((link, i) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      scrollToIndex(i);
    });
  });

  let scrollTimer: ReturnType<typeof setTimeout>;
  track?.addEventListener("scroll", () => {
    if (isScrolling) return;
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(() => {
      const cw = getCardWidth();
      currentIndex = Math.round(track.scrollLeft / cw);
      updateActive();
    }, 80);
  });

  // Initial update
  updateActive();
</script>
