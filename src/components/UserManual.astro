---
const videos = [
  {
    title: "Configuración inicial del sistema",
    description:
      "Un recorrido rápido por la configuración inicial de Caribe Suite: desde la bienvenida y creación del administrador hasta la empresa, moneda, cuentas contables, métodos de pago, clientes, proveedores, inventario y capital inicial. Todo lo necesario para dejar tu sistema listo para trabajar.",
    videoId: "TBv9xDPtl0U",
  },
];
---

<section id="manual" class="manual-section">
  <div class="manual-container">
    <!-- Header -->
    <div class="manual-header">
      <h2 class="manual-title">Manual de Usuario</h2>
      <p class="manual-subtitle">
        Aquí aparecerán los <strong>video‑tutoriales</strong> del sistema, organizados
        para guiarte paso a paso en cada proceso. A medida que agreguemos nuevos videos,
        esta sección se irá actualizando automáticamente.
      </p>
    </div>

    <!-- Body: sidebar + gallery -->
    <div class="manual-body">
      <!-- Table of Contents -->
      <aside class="toc" id="toc">
        <p class="toc-label">Contenido</p>
        <nav>
          <ol class="toc-list">
            {
              videos.map((video, i) => (
                <li>
                  <a href={`#video-${i}`} class="toc-link" data-index={i}>
                    <span class="toc-num">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <span class="toc-text">{video.title}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </nav>
      </aside>

      <!-- Horizontal Gallery -->
      <div class="gallery-wrapper">
        <div class="gallery-track" id="gallery-track">
          {
            videos.map((video, i) => (
              <article class="video-card" id={`video-${i}`} data-index={i}>
                <div class="video-embed">
                  <iframe
                    src={`https://www.youtube.com/embed/${video.videoId}`}
                    title={video.title}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    referrerpolicy="strict-origin-when-cross-origin"
                    allowfullscreen
                  />
                </div>
                <div class="video-info">
                  <span class="video-index">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <h3 class="video-title">{video.title}</h3>
                  <p class="video-desc">{video.description}</p>
                </div>
              </article>
            ))
          }
        </div>

        <!-- Navigation arrows -->
        <button
          class="gallery-btn gallery-btn--prev"
          id="btn-prev"
          aria-label="Anterior"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path
              d="M12.5 15L7.5 10L12.5 5"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <button
          class="gallery-btn gallery-btn--next"
          id="btn-next"
          aria-label="Siguiente"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path
              d="M7.5 5L12.5 10L7.5 15"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>

        <!-- Dots -->
        <div class="gallery-dots" id="gallery-dots">
          {
            videos.map((_, i) => (
              <button
                class={`dot ${i === 0 ? "dot--active" : ""}`}
                data-dot={i}
                aria-label={`Ir al video ${i + 1}`}
              />
            ))
          }
        </div>

        <!-- Mobile counter: "1 / 8" -->
        <div class="gallery-counter" id="gallery-counter" aria-live="polite">
          <span class="gallery-counter-current" id="counter-current">1</span>
          <span style="opacity:0.35">/</span>
          <span>{videos.length}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── tokens (shadcn-style neutral) ── */
  .manual-section {
    --c-bg: #ffffff;
    --c-surface: #f9f9f8;
    --c-border: #e4e4e3;
    --c-border-md: #d1d0ce;
    --c-text: #111110;
    --c-muted: #6b6b69;
    --c-subtle: #a1a09e;
    --c-accent-bg: #111110;
    --c-accent-fg: #ffffff;
    --radius-sm: 6px;
    --radius-md: 8px;
    --radius-lg: 12px;
  }

  /* ── Base ── */
  .manual-section {
    padding: 5rem 1.5rem;
    background: var(--c-bg);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
  }

  .manual-container {
    max-width: 72rem;
    margin: 0 auto;
  }

  /* ── Header ── */
  .manual-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .manual-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: var(--c-text);
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .manual-subtitle {
    color: var(--c-muted);
    font-size: 0.9375rem;
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.65;
  }

  .manual-subtitle strong {
    color: var(--c-text);
    font-weight: 500;
  }

  /* ── Layout ── */
  .manual-body {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  /* ── TOC ── */
  .toc {
    flex: 0 0 196px;
    /* Stretch to match the gallery-wrapper height */
    align-self: stretch;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: 1rem 0.75rem;
    /* Scroll inside when list overflows */
    overflow-y: auto;
    box-sizing: border-box;
  }

  .toc-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-subtle);
    margin: 0 0 0.5rem 0.375rem;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .toc-link {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.4375rem 0.5rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.1s;
    color: var(--c-muted);
  }

  .toc-link:hover {
    background: var(--c-border);
    color: var(--c-text);
  }

  .toc-link.toc-link--active {
    background: var(--c-accent-bg);
    color: var(--c-accent-fg);
  }

  .toc-num {
    font-size: 0.6875rem;
    font-weight: 500;
    color: inherit;
    opacity: 0.5;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .toc-link--active .toc-num {
    opacity: 0.65;
  }

  .toc-text {
    font-size: 0.8125rem;
    line-height: 1.4;
    font-weight: 400;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* ── Gallery wrapper ── */
  .gallery-wrapper {
    flex: 1;
    min-width: 0;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .gallery-track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding-bottom: 0.5rem;
    padding-top: 2px;
    padding-left: 1px;
    scrollbar-width: thin;
    scrollbar-color: var(--c-border-md) transparent;
  }

  .gallery-track::-webkit-scrollbar {
    height: 3px;
  }
  .gallery-track::-webkit-scrollbar-track {
    background: transparent;
  }
  .gallery-track::-webkit-scrollbar-thumb {
    background: var(--c-border-md);
    border-radius: 99px;
  }

  /* ── Video Card ── */
  .video-card {
    flex: 0 0 clamp(260px, 42vw, 340px);
    scroll-snap-align: start;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .video-card:hover {
    border-color: var(--c-border-md);
  }

  .video-embed {
    aspect-ratio: 16 / 9;
    background: var(--c-surface);
  }

  .video-embed iframe {
    width: 100%;
    height: 100%;
    display: block;
    border: none;
  }

  .video-info {
    padding: 0.875rem 1rem 1rem;
    border-top: 1px solid var(--c-border);
  }

  .video-index {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--c-subtle);
    margin-bottom: 0.25rem;
    font-variant-numeric: tabular-nums;
  }

  .video-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--c-text);
    margin: 0 0 0.3rem;
    line-height: 1.4;
  }

  .video-desc {
    font-size: 0.8125rem;
    color: var(--c-muted);
    margin: 0;
    line-height: 1.55;
  }

  /* ── Navigation buttons ── */
  .gallery-btn {
    display: none;
    position: absolute;
    top: calc(50% - 2rem);
    transform: translateY(-50%);
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    color: var(--c-text);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition:
      background 0.1s,
      border-color 0.1s;
    z-index: 2;
  }

  .gallery-btn:hover {
    background: var(--c-surface);
    border-color: var(--c-border-md);
  }

  .gallery-btn--prev {
    left: -1rem;
  }
  .gallery-btn--next {
    right: -1rem;
  }

  /* ── Dots ── */
  .gallery-dots {
    display: flex;
    gap: 0.3rem;
    justify-content: center;
    margin-top: 1rem;
  }

  .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--c-border-md);
    border: none;
    cursor: pointer;
    padding: 0;
    transition:
      background 0.15s,
      transform 0.15s;
  }

  .dot--active {
    background: var(--c-text);
    transform: scale(1.5);
  }

  /* Counter hidden by default; shown only on mobile */
  .gallery-counter {
    display: none;
  }

  /* ── Responsive: tablet ── */
  @media (max-width: 900px) {
    .manual-body {
      flex-direction: column;
      gap: 1rem;
    }

    .toc {
      position: static;
      flex: none;
      width: 100%;
      max-height: none;
      overflow: visible;
      padding: 0.75rem;
    }

    .toc-list {
      flex-direction: row;
      flex-wrap: nowrap;
      overflow-x: auto;
      gap: 0.25rem;
      padding-bottom: 0.125rem;
      scrollbar-width: none;
    }

    .toc-list::-webkit-scrollbar {
      display: none;
    }

    .toc-link {
      white-space: nowrap;
      padding: 0.375rem 0.5rem;
    }

    .toc-text {
      display: block;
      -webkit-line-clamp: 1;
    }

    .video-card {
      flex: 0 0 clamp(260px, 68vw, 360px);
    }

    .gallery-btn {
      display: flex;
    }
  }

  /* ── Responsive: mobile ── */
  @media (max-width: 560px) {
    .manual-section {
      padding: 3rem 0;
    }

    .manual-container {
      padding: 0 1.25rem;
    }

    .manual-header {
      margin-bottom: 1.5rem;
      text-align: left;
    }

    .manual-subtitle {
      font-size: 0.9rem;
      text-align: left;
    }

    .toc {
      display: none;
    }

    .gallery-wrapper {
      width: 100%;
    }

    .gallery-track {
      margin: 0 -1.25rem;
      padding-left: 1.25rem;
      padding-right: 1.25rem;
      gap: 0.875rem;
      scrollbar-width: none;
    }

    .gallery-track::-webkit-scrollbar {
      display: none;
    }

    .video-card {
      flex: 0 0 calc(100vw - 2.5rem);
      border-radius: var(--radius-md);
    }

    .video-info {
      padding: 0.875rem 1rem;
    }
    .video-title {
      font-size: 0.875rem;
    }
    .video-desc {
      font-size: 0.8rem;
    }

    .gallery-dots {
      display: none;
    }
    .gallery-btn {
      display: none !important;
    }

    .gallery-counter {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      margin-top: 0.75rem;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--c-muted);
    }

    .gallery-counter-current {
      color: var(--c-text);
      font-weight: 600;
    }
  }
</style>

<script>
  const track = document.getElementById("gallery-track") as HTMLElement;
  const btnPrev = document.getElementById("btn-prev") as HTMLButtonElement;
  const btnNext = document.getElementById("btn-next") as HTMLButtonElement;
  const dots = document.querySelectorAll<HTMLButtonElement>(".dot");
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
  const counterCurrent = document.getElementById("counter-current");

  let currentIndex = 0;

  function getCardWidth(): number {
    const card = track.querySelector<HTMLElement>(".video-card");
    if (!card) return 300;
    const style = getComputedStyle(track);
    const gap = parseFloat(style.gap) || 24;
    return card.offsetWidth + gap;
  }

  function scrollToIndex(index: number) {
    currentIndex = Math.max(0, Math.min(index, dots.length - 1));
    track.scrollTo({ left: currentIndex * getCardWidth(), behavior: "smooth" });
    updateActive();
  }

  function updateActive() {
    dots.forEach((d, i) =>
      d.classList.toggle("dot--active", i === currentIndex),
    );
    tocLinks.forEach((l, i) =>
      l.classList.toggle("toc-link--active", i === currentIndex),
    );
    if (counterCurrent) counterCurrent.textContent = String(currentIndex + 1);
  }

  // Arrow buttons — only shown on tablet via CSS
  btnPrev.addEventListener("click", () => scrollToIndex(currentIndex - 1));
  btnNext.addEventListener("click", () => scrollToIndex(currentIndex + 1));

  // Dot clicks
  dots.forEach((dot, i) =>
    dot.addEventListener("click", () => scrollToIndex(i)),
  );

  // TOC link clicks
  tocLinks.forEach((link, i) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      scrollToIndex(i);
    });
  });

  // Update active on manual scroll
  let scrollTimer: ReturnType<typeof setTimeout>;
  track.addEventListener("scroll", () => {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(() => {
      const cw = getCardWidth();
      currentIndex = Math.round(track.scrollLeft / cw);
      updateActive();
    }, 80);
  });

  updateActive();
</script>
