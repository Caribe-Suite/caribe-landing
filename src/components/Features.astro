---
import FeatureCard from './FeatureCard.astro';
import { Box, BarChart3, ShoppingCart, ShieldCheck } from '@lucide/astro';

const features = [
    {
        title: "Inventario",
        description: "Control total de existencias, compras, ventas, ajustes y producción.",
        icon: Box,
        items: [
            "Gestión de productos",
            "Compras y Ventas",
            "Ajustes de stock",
            "Producción y transformación"
        ]
    },
    {
        title: "Contabilidad",
        description: "Estados financieros en tiempo real, cuentas por cobrar/pagar y plan de cuentas flexible.",
        icon: BarChart3,
        items: [
            "Asientos automáticos",
            "Reportes financieros",
            "Control de cobros/pagos",
            "Plan contable personalizable"
        ]
    },
    {
        title: "Punto de Venta (POS)",
        description: "Interfaz optimizada para ventas rápidas, tickets y facturas, múltiples métodos de pago.",
        icon: ShoppingCart,
        items: [
            "Ventas rápidas",
            "Impresión de tickets",
            "Múltiples cajas/turnos",
            "Pagos diversos"
        ]
    },
    {
        title: "Control Administrativo",
        description: "Gestión de usuarios, roles, centros de costo, monedas y entidades.",
        icon: ShieldCheck,
        items: [
            "Gestión de roles",
            "Control de accesos",
            "Multi-moneda",
            "Configuración de entidades"
        ]
    }
];
---

<section id="features" class="py-24 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-20">
            <h3 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-6 uppercase tracking-tight">Todo lo que tu empresa necesita</h3>
            <p class="text-slate-600 max-w-2xl mx-auto text-base md:text-lg leading-relaxed max-sm:text-left">
                Caribe Suite combina las herramientas esenciales en una sola solución integrada y fácil de usar.
            </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            {features.map(feature => (
                <FeatureCard {...feature} />
            ))}
        </div>
    </div>
</section>
