---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Caribe Suite - Plataforma integral de gestión empresarial" />
		<meta name="viewport" content="width=device-width" />

		<!-- Favicons correctos para GitHub Pages -->
		<link rel="icon" type="image/png" href="/caribe-landing/favicon.png" />
		<link rel="icon" href="/caribe-landing/favicon.ico" />

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col font-sans">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-slate-900 focus:ring-2 focus:ring-slate-900 focus:rounded-lg shadow-xl font-bold">
			Saltar al contenido principal
		</a>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
	html {
		font-family: system-ui, sans-serif;
		scroll-behavior: smooth;
	}
</style>
